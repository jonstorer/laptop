#!/bin/sh

# Welcome to the mac-openclaw machine script!
# Sets up macOS as an iMessage bridge for a ubuntu-openclaw installation.
# BlueBubbles exposes Messages.app via web API; ubuntu-openclaw connects to it
# via the @openclaw/imessage plugin.
# After this script completes, follow the manual steps shown in the summary.

# Ask for sudo upfront so we don't have to get it later
sudo -v

# Keep using sudo so the permissions don't time out
while true; do sudo -n true; sleep 10; kill -0 "$$" || exit; done 2>/dev/null &

# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && printf "failed\n\n" >&2; exit $ret' EXIT
set -e

###############################################################################
# Homebrew                                                                    #
###############################################################################

if ! command -v brew > /dev/null 2>&1; then
  echo "Installing Homebrew ..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL 'https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh')"
fi

# x86_64: /usr/local  |  arm64: /opt/homebrew
if [ "$(uname -m)" = "arm64" ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi

echo "Updating Homebrew ..."
brew update --force

brew bundle --file=- <<EOF
# GUI apps -- for physical access / debugging
cask "alfred"
cask "bluebubbles"
cask "iterm2"
cask "rectangle"

# Browser -- used by BlueBubbles web interface
cask "google-chrome"

# Config manipulation
brew "jq"
brew "yq"

# Networking
brew "curl"
brew "wget"
brew "tailscale"

# Terminal multiplexer
brew "tmux"
EOF

brew upgrade

###############################################################################
# SSH -- enable Remote Login for remote access                               #
###############################################################################

# systemsetup -setremotelogin silently fails on Sonoma; use launchctl directly
# load -w exits 37 if already loaded, which is fine; verify it's running after
sudo launchctl load -w /System/Library/LaunchDaemons/ssh.plist 2>/dev/null || true
sudo launchctl list com.openssh.sshd > /dev/null 2>&1 || { echo "ERROR: SSH daemon failed to start" >&2; exit 1; }

###############################################################################
# Screen Sharing -- enable VNC for remote desktop                            #
###############################################################################

sudo launchctl load -w /System/Library/LaunchDaemons/com.apple.screensharing.plist 2>/dev/null || true
sudo launchctl list com.apple.screensharing > /dev/null 2>&1 || { echo "ERROR: Screen Sharing failed to start" >&2; exit 1; }

###############################################################################
# Tailscale -- start daemon (run 'sudo tailscale up' to authenticate)       #
###############################################################################

sudo brew services start tailscale

###############################################################################
# Internet Sharing -- en2 (WiFi) to en0, en1 (Ethernet)                     #
###############################################################################

# com.apple.nat.plist is already configured -- just ensure the service is running
sudo launchctl load -w /System/Library/LaunchDaemons/com.apple.InternetSharing.plist 2>/dev/null || true

###############################################################################
# poke-messages -- keep Messages.app alive for BlueBubbles                  #
###############################################################################

# Messages.app can go idle on autonomous setups and miss incoming messages.
# This LaunchAgent pokes it every 5 minutes to keep it responsive.
POKE_SCRIPT="$HOME/Scripts/poke-messages.scpt"
POKE_PLIST="$HOME/Library/LaunchAgents/com.user.poke-messages.plist"

mkdir -p "$HOME/Scripts"
cat > "$POKE_SCRIPT" <<'SCPT'
tell application "Messages"
    launch
    count every chat
end tell
SCPT

mkdir -p "$HOME/Library/LaunchAgents"
cat > "$POKE_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.poke-messages</string>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/osascript</string>
        <string>$HOME/Scripts/poke-messages.scpt</string>
    </array>
</dict>
</plist>
EOF

# Idempotent load: unload if already running, then reload
launchctl bootout "gui/$(id -u)/com.user.poke-messages" 2>/dev/null || true
launchctl bootstrap "gui/$(id -u)" "$POKE_PLIST"

###############################################################################
# zsh                                                                         #
###############################################################################

shell_path="$(command -v zsh)"
echo "Ensuring default shell is zsh at '$shell_path' ..."
if ! grep "$shell_path" /etc/shells > /dev/null 2>&1; then
  sudo sh -c "echo $shell_path >> /etc/shells"
fi
if [ "$SHELL" != "$shell_path" ]; then
  sudo chsh -s "$shell_path" "$USER"
fi

###############################################################################
# macOS defaults -- automation-friendly only                                 #
###############################################################################

echo "Configuring macOS defaults ..."

# Keep background processes alive
defaults write NSGlobalDomain NSDisableAutomaticTermination -bool true

# No iCloud document syncing
defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false

# Reveal IP address, hostname, OS version when clicking clock in login window
sudo defaults write /Library/Preferences/com.apple.loginwindow AdminHostInfo HostName

# Locale
defaults write NSGlobalDomain AppleLanguages -array "en"
defaults write NSGlobalDomain AppleLocale -string "en_US@currency=USD"
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

# Require password immediately after screensaver
defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0

# No .DS_Store on network volumes
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true

# No confirmation dialogs that could block automation
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false
defaults write com.apple.finder WarnOnEmptyTrash -bool false

for app in "Dock" "Finder" "SystemUIServer"; do
  killall "$app" > /dev/null 2>&1 || true
done

echo "macOS defaults configured."

###############################################################################
# TODO.md -- manual steps with live status                                   #
###############################################################################

_ok() { sh -c "$1" > /dev/null 2>&1 && printf 'x' || printf ' '; }

_TS=$(_ok "tailscale status")
_BB=$(_ok "pgrep -x BlueBubbles")
_GENERATED=$(date '+%Y-%m-%d %H:%M:%S')
TODO_FILE="$HOME/TODO.md"

cat > "$TODO_FILE" <<EOF
# Mac OpenClaw Setup

_Last updated: $_GENERATED — rerun mac-openclaw to refresh status._

- [$_TS] Authenticate Tailscale: \`sudo tailscale up\`
- [$_BB] Launch BlueBubbles, sign in with Apple ID, enable REST API (Settings → Server → enable REST API), note the server URL and password
- [ ] Approve Automation permission — macOS will prompt when osascript first accesses Messages.app; allow in System Settings → Privacy & Security → Automation
- [ ] Sign into iMessage — Messages.app → Settings → iMessage
- [ ] On the Ubuntu machine run \`openclaw configure\` and supply the BlueBubbles server URL and password
EOF

###############################################################################
# Summary                                                                     #
###############################################################################

LOCAL_IP="$(ipconfig getifaddr en2 2>/dev/null || echo 'unknown')"

echo ""
echo "============================================================"
echo "Setup complete. This Mac is an iMessage bridge for ubuntu-openclaw."
echo ""
echo "Local IP (WiFi):  $LOCAL_IP"
echo "SSH:              ssh $USER@$LOCAL_IP"
echo "Screen Sharing:   vnc://$LOCAL_IP"
echo ""
echo "Tailscale: daemon started -- run 'sudo tailscale up' to authenticate."
echo "After auth, SSH and Screen Sharing work from anywhere via Tailscale IP."
echo ""
echo "Manual steps: $TODO_FILE"
echo "============================================================"
