# Welcome to the machine script!

Write-Host "Running laptop script..."

# Require Administrator for WSL installation
$isAdmin = ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
if (-Not $isAdmin) {
  Write-Host "This script must be run as Administrator (required for WSL setup). Right-click PowerShell and 'Run as Administrator'." -ForegroundColor Red
  exit 1
}

Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process -Force

# Ensure PowerShell profile exists (dotfiles are *nix only - no Windows configs)
if (-Not (Test-Path -Path $PROFILE -PathType Leaf)) {
  Write-Host "Creating profile at '$PROFILE'"
  New-Item -Path (Split-Path -Path $PROFILE) -ItemType Directory -Force | Out-Null
  New-Item -Path $PROFILE -ItemType File -Force | Out-Null
}

# Install WSL and Ubuntu if not present
$wslReady = $false
try {
  $null = wsl -e echo "ok" 2>&1
  if ($LASTEXITCODE -eq 0) {
    $wslReady = $true
  }
} catch {
  # WSL not available
}

if (-Not $wslReady) {
  Write-Host "Installing WSL and Ubuntu ..."
  Write-Host "This may require a reboot. If prompted, restart your computer and run this script again." -ForegroundColor Yellow
  wsl --install -d Ubuntu --no-launch

  # Check if reboot is needed (WSL often requires reboot after first install)
  Start-Sleep -Seconds 8
  $wslReady = $false
  try {
    $null = wsl -e echo "ok" 2>&1
    if ($LASTEXITCODE -eq 0) { $wslReady = $true }
  } catch { }

  if (-Not $wslReady) {
    Write-Host ""
    Write-Host "WSL installation requires a reboot. Please restart your computer, then run this script again." -ForegroundColor Yellow
    exit 0
  }
}

Write-Host "WSL is ready."

# Install or update Chocolatey (for Windows apps)
if (-Not (Get-Command choco -ErrorAction SilentlyContinue)) {
  Write-Host "Installing Chocolatey ..."
  [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
  iex ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))
} else {
  Write-Host "Updating Chocolatey ..."
  choco upgrade chocolatey -y
}

# Reload PATH so choco is available in the current session after a fresh install
$env:PATH = [System.Environment]::GetEnvironmentVariable("PATH", "Machine") + ";" + [System.Environment]::GetEnvironmentVariable("PATH", "User")

Write-Host "Installing Windows applications ..."

choco upgrade -y `
  git `
  vscode `
  docker-desktop `
  googlechrome `
  slack `
  powershell

Write-Host ""
Write-Host "Step 1 complete. Your Windows machine is ready for the Ubuntu environment." -ForegroundColor Green
Write-Host ""
Write-Host "Next: Run the Ubuntu script inside WSL to set up asdf, Node.js, zsh, and dev tools." -ForegroundColor Yellow
Write-Host "See the README for instructions. You will need to:" -ForegroundColor Yellow
Write-Host "  1. Open WSL (run 'wsl' or open Windows Terminal)" -ForegroundColor Cyan
Write-Host "  2. If first time: complete Ubuntu username/password setup" -ForegroundColor Cyan
Write-Host "  3. Run the Ubuntu script from the README (use LAPTOP_SKIP_DOCKER=1 for WSL)" -ForegroundColor Cyan
Write-Host ""
Write-Host "Docker: Enable 'Use the WSL 2 based engine' in Docker Desktop Settings > General." -ForegroundColor Cyan
