#!/bin/sh

# Welcome to the ubuntu-openclaw machine script!
# Sets up Ubuntu x86_64 to run OpenClaw as a persistent autonomous agent.

# Ask for sudo upfront so we don't have to get it later
sudo -v

# Keep using sudo so the permissions don't time out by updating existing sudo time stamp if set, otherwise do nothing.
while true; do sudo -n true; sleep 10; kill -0 "$$" || exit; done 2>/dev/null &

# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && printf "failed\n\n" >&2; exit $ret' EXIT
set -e

###############################################################################
# Cleanup — remove packages not needed for headless autonomous operation      #
###############################################################################

sudo apt remove --purge -y \
  ubuntu-desktop-minimal \
  gnome-remote-desktop \
  gdm3 \
  lightdm \
  xrdp \
  xorgxrdp \
  2>/dev/null || true

sudo apt autoremove --purge -y

# Remove snap Chromium if present — OpenClaw requires the deb version
if snap list chromium 2>/dev/null | grep -q chromium; then
  sudo snap remove chromium
fi

rm -f "$HOME/.xsession"

# Wait for apt locks to be released
wait_for_apt() {
  echo "Waiting for apt lock..."
  while sudo fuser /var/lib/apt/lists/lock /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
    sleep 3
  done
}

sudo apt update
sudo apt full-upgrade -y

sudo apt-get install -y ca-certificates gnupg wget

if [ ! -e "/etc/apt/keyrings/docker.gpg" ]; then
  sudo install -m 0755 -d /etc/apt/keyrings
  wget -qO- https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  sudo chmod a+r /etc/apt/keyrings/docker.gpg

# shellcheck disable=SC1091
  echo \
    "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
    $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | \
    sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
fi

wait_for_apt
sudo apt update

apt_packages="build-essential gcc g++ cmake make git libssl-dev zsh htop jq vim tmux watch silversearcher-ag shellcheck curl openssh-server xclip docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin"
# shellcheck disable=SC2086
sudo apt install -y $apt_packages

sudo usermod -aG docker "$USER"

# Node.js v22 via NodeSource
if ! node --version 2>/dev/null | grep -q '^v22\.'; then
  echo "Installing Node.js v22 ..."
  wait_for_apt
  wget -qO- https://deb.nodesource.com/setup_22.x | sudo -E bash -
  sudo apt install -y nodejs
fi

# Configure npm to use a user-owned prefix so global installs never need sudo
NPM_GLOBAL="$HOME/.npm-global"
mkdir -p "$NPM_GLOBAL"
npm config set prefix "$NPM_GLOBAL"
export PATH="$NPM_GLOBAL/bin:$PATH"
if ! grep -q 'NPM_GLOBAL' "$HOME/.zshrc" 2>/dev/null; then
  printf '\nexport NPM_GLOBAL="$HOME/.npm-global"\nexport PATH="$NPM_GLOBAL/bin:$PATH"\n' >> "$HOME/.zshrc"
fi

# Claude Code
npm install -g @anthropic-ai/claude-code

# SSH
sudo systemctl enable ssh
sudo systemctl start ssh

###############################################################################
# Tailscale                                                                   #
###############################################################################

wait_for_apt
if ! command -v tailscale > /dev/null 2>&1; then
  echo "Installing Tailscale ..."
  wget -qO- https://tailscale.com/install.sh | sh
fi
sudo systemctl enable tailscaled
sudo systemctl start tailscaled

###############################################################################
# llama.cpp                                                                   #
###############################################################################

sudo mkdir -p /opt/openclaw/llama.cpp
sudo chown -R "$USER":"$USER" /opt/openclaw

if [ ! -d "/opt/openclaw/llama.cpp/.git" ]; then
  git clone https://github.com/ggerganov/llama.cpp.git /opt/openclaw/llama.cpp
  llama_pull_output="(fresh clone)"
else
  llama_pull_output=$(git -C /opt/openclaw/llama.cpp pull)
fi

if [ ! -f "/opt/openclaw/llama.cpp/build/bin/llama-server" ] || \
   [ "$(echo "$llama_pull_output" | grep -c 'Already up to date.')" -eq 0 ]; then
  echo "Building llama.cpp ..."
  cmake -B /opt/openclaw/llama.cpp/build \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_AVX2=ON \
    -DGGML_F16C=ON \
    -DGGML_FMA=ON \
    -DGGML_CUDA=OFF \
    -DLLAMA_BUILD_SERVER=ON \
    /opt/openclaw/llama.cpp
  cmake --build /opt/openclaw/llama.cpp/build --config Release -j "$(nproc)"
else
  echo "llama.cpp is up to date, skipping build."
fi

###############################################################################
# llama-server systemd service (model downloaded via -hf on first start)     #
###############################################################################

HF_AUTHOR="${HF_AUTHOR:-bartowski}"
HF_BASE_MODEL="${HF_BASE_MODEL:-mistralai_Mistral-Small-3.2-24B-Instruct-2506}"
HF_QUANT="${HF_QUANT:-Q4_K_M}"
HF_REPO="${HF_REPO:-${HF_AUTHOR}/${HF_BASE_MODEL}-GGUF}"

if [ -z "$HF_TOKEN" ]; then
  echo ""
  echo "A HuggingFace account and token are required to download this model."
  echo "  1. Create an account at https://huggingface.co if you don't have one."
  echo "  2. Accept the model license at: https://huggingface.co/${HF_REPO}"
  echo "  3. Create a read-only token at: https://huggingface.co/settings/tokens"
  echo ""
  printf "Paste your HuggingFace token and press Enter: "
  read -r HF_TOKEN < /dev/tty
fi

if [ -z "$HF_TOKEN" ]; then
  echo "WARNING: No HuggingFace token provided. The model download may fail."
  echo "Re-run with: HF_TOKEN=hf_yourtoken $0"
fi

sudo mkdir -p /opt/openclaw/models
sudo chown -R "$USER":"$USER" /opt/openclaw

# Physical core count: "Core(s) per socket" * "Socket(s)" (excludes hyperthreads)
LLAMA_THREADS=$(( \
  $(lscpu | awk '/^Core\(s\) per socket:/ {print $NF}') * \
  $(lscpu | awk '/^Socket\(s\):/ {print $NF}') \
))

# Total RAM in GB (MemTotal from /proc/meminfo is in kB)
total_ram_kb=$(awk '/^MemTotal:/ {print $2}' /proc/meminfo)
total_ram_gb=$(( total_ram_kb / 1024 / 1024 ))

# Model size via Content-Length header (follow redirects)
HF_MODEL_URL="https://huggingface.co/${HF_REPO}/resolve/main/${HF_BASE_MODEL}-${HF_QUANT}.gguf"
MODEL_SIZE_BYTES=$(curl -sIL "$HF_MODEL_URL" | awk '/^[Cc]ontent-[Ll]ength:/ {val=$2} END {print val+0}')
MODEL_SIZE_GB=$(( (MODEL_SIZE_BYTES + 1073741823) / 1073741824 ))
if [ "$MODEL_SIZE_BYTES" -eq 0 ]; then
  echo "WARNING: Could not determine model size, falling back to 14GB estimate."
  MODEL_SIZE_GB=14
fi

# Parallel slots: floor((RAM - model) / 2), clamped to [1, 8]
AVAILABLE_RAM_GB=$(( total_ram_gb - MODEL_SIZE_GB ))
LLAMA_PARALLEL=$(( AVAILABLE_RAM_GB / 2 ))
if [ "$LLAMA_PARALLEL" -lt 1 ]; then LLAMA_PARALLEL=1; fi
if [ "$LLAMA_PARALLEL" -gt 8 ]; then LLAMA_PARALLEL=8; fi

# Context size based on RAM tier
if [ "$total_ram_gb" -le 16 ]; then
  LLAMA_CTX_SIZE=4096
elif [ "$total_ram_gb" -le 32 ]; then
  LLAMA_CTX_SIZE=8192
elif [ "$total_ram_gb" -le 64 ]; then
  LLAMA_CTX_SIZE=16384
else
  LLAMA_CTX_SIZE=32768
fi

sudo tee /etc/systemd/system/llama-server.service > /dev/null <<EOF
[Unit]
Description=llama-server OpenAI-compatible inference server
After=network.target

[Service]
Type=simple
User=$USER
Environment=HF_HOME=/opt/openclaw/models
ExecStart=/opt/openclaw/llama.cpp/build/bin/llama-server \
  --model-url ${HF_MODEL_URL} \
  --host 127.0.0.1 --port 8080 \
  --ctx-size ${LLAMA_CTX_SIZE} \
  --threads ${LLAMA_THREADS} \
  --parallel ${LLAMA_PARALLEL} \
  --flash-attn on
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable llama-server
sudo systemctl restart llama-server

###############################################################################
# zsh                                                                         #
###############################################################################

shell_path="$(command -v zsh)"
echo "Ensure shell is zsh at '$shell_path' ..."
if ! grep "$shell_path" /etc/shells > /dev/null 2>&1 ; then
  echo "Add '$shell_path' to /etc/shells"
  sudo sh -c "echo $shell_path >> /etc/shells"
fi
sudo chsh -s "$shell_path" "$USER"

###############################################################################
# OpenClaw                                                                    #
###############################################################################

OPENCLAW_LATEST=$(npm view openclaw version 2>/dev/null || true)
OPENCLAW_INSTALLED=$(openclaw --version 2>/dev/null | awk '{print $2}' || true)

if [ "$OPENCLAW_INSTALLED" = "$OPENCLAW_LATEST" ]; then
  echo "OpenClaw $OPENCLAW_INSTALLED is already up to date, skipping."
else
  echo "Installing/updating OpenClaw ($OPENCLAW_INSTALLED -> $OPENCLAW_LATEST) ..."
  wget -q -O /tmp/openclaw-install.sh 'https://openclaw.ai/install.sh'
  OPENCLAW_NO_ONBOARD=1 OPENCLAW_NO_PROMPT=1 bash /tmp/openclaw-install.sh --no-onboard --no-prompt
  rm -f /tmp/openclaw-install.sh
  echo ""
  echo "OpenClaw is installed. Run 'openclaw onboard' to configure when ready."
fi

###############################################################################
# OpenClaw browser config — headless Chromium via Playwright                 #
###############################################################################

# Install real deb Chromium — Ubuntu 24.04 redirects both 'chromium' and
# 'chromium-browser' to a snap wrapper, so we pull directly from the
# Debian archive instead
if ! command -v chromium-browser > /dev/null 2>&1 || snap list chromium > /dev/null 2>&1; then
  sudo snap remove chromium 2>/dev/null || true
  sudo apt remove --purge -y chromium-browser 2>/dev/null || true

  # Add Debian bookworm archive for real chromium deb
  wget -qO- https://dl-ssl.google.com/linux/linux_signing_key.pub \
    | sudo gpg --dearmor -o /etc/apt/keyrings/google-chrome.gpg
  echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/google-chrome.gpg] \
    http://dl.google.com/linux/chrome/deb/ stable main" \
    | sudo tee /etc/apt/sources.list.d/google-chrome.list > /dev/null
  sudo apt update
  sudo apt install -y google-chrome-stable
fi

mkdir -p "$HOME/.openclaw"

OCJSON="$HOME/.openclaw/openclaw.json"

if [ -f "$OCJSON" ]; then
  tmp=$(mktemp)
  jq '.browser = {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "noSandbox": true
  }' "$OCJSON" > "$tmp" && mv "$tmp" "$OCJSON"
else
  cat > "$OCJSON" <<EOF
{
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "noSandbox": true
  }
}
EOF
fi

###############################################################################
# Summary                                                                     #
###############################################################################

LOCAL_IP="$(hostname -I | awk '{print $1}')"

echo ""
echo "============================================================"
echo "Setup complete."
echo ""
echo "Local IP:     $LOCAL_IP"
echo "SSH:          ssh $USER@$LOCAL_IP"
echo "Browser:      headless Google Chrome (openclaw profile, noSandbox)"
echo "llama-server: http://127.0.0.1:8080/v1"
echo ""
echo "llama-server config (derived from hardware):"
echo "  --threads  $LLAMA_THREADS  (physical cores)"
echo "  --parallel $LLAMA_PARALLEL  (slots)"
echo "  --ctx-size $LLAMA_CTX_SIZE"
echo "  model:     ${HF_BASE_MODEL}-${HF_QUANT}.gguf (${MODEL_SIZE_GB}GB)"
echo "  available: ${AVAILABLE_RAM_GB}GB for KV cache  (RAM: ${total_ram_gb}GB)"
echo ""
echo "Next steps:"
echo "  1. Open a new terminal  (so PATH changes from this script take effect)"
echo "  2. tailscale up         (authenticate Tailscale for internet access)"
echo "  3. openclaw onboard     (configure OpenClaw when ready)"
echo "============================================================"

