#!/bin/sh

# Welcome to the ubuntu-openclaw machine script!
# Sets up Ubuntu 26.04 LTS Desktop (amd64) as a complete standalone OpenClaw installation.
# OpenClaw gateway + Claude CLI backend + WhatsApp channel. No Mac required.
# After this script completes, follow the manual steps shown in the summary.

# Ask for sudo upfront so we don't have to get it later
sudo -v

# Keep using sudo so the permissions don't time out
while true; do sudo -n true; sleep 10; kill -0 "$$" || exit; done 2>/dev/null &

# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && printf "failed\n\n" >&2; exit $ret' EXIT
set -e

# Wait for apt locks to be released
wait_for_apt() {
  echo "Waiting for apt lock..."
  while sudo fuser /var/lib/apt/lists/lock /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
    sleep 3
  done
}

###############################################################################
# System packages                                                             #
###############################################################################

wait_for_apt
sudo apt update
sudo apt full-upgrade -y

sudo apt install -y \
  build-essential \
  ca-certificates \
  curl \
  file \
  git \
  gnupg \
  htop \
  jq \
  pipx \
  procps \
  python3-pip \
  ripgrep \
  tmux \
  trash-cli \
  vim \
  wget \
  xclip \
  yq \
  zsh

###############################################################################
# Homebrew -- required by OpenClaw on Linux                                  #
###############################################################################

if ! command -v brew > /dev/null 2>&1; then
  echo "Installing Homebrew ..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL 'https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh')"
fi

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

ZPROFILE="$HOME/.zprofile"
if ! grep -qF 'linuxbrew' "$ZPROFILE" 2>/dev/null; then
  # shellcheck disable=SC2016
  printf '\neval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"\n' >> "$ZPROFILE"
fi

###############################################################################
# gogcli -- Google Workspace CLI, required for OpenClaw Google integration   #
###############################################################################

if ! command -v gogcli > /dev/null 2>&1; then
  echo "Installing gogcli ..."
  brew install gogcli
else
  echo "gogcli already installed, skipping."
fi

###############################################################################
# GitHub CLI -- official apt repository                                       #
###############################################################################

if ! command -v gh > /dev/null 2>&1; then
  echo "Installing GitHub CLI ..."
  sudo install -d -m 0755 /usr/share/keyrings
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | sudo tee /usr/share/keyrings/githubcli-archive-keyring.gpg > /dev/null
  sudo chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
  wait_for_apt
  sudo apt update
  sudo apt install -y gh
else
  echo "GitHub CLI already installed, skipping."
fi

###############################################################################
# Node.js v22 -- via NodeSource (deb822 format, distro-agnostic)             #
###############################################################################

if ! node --version 2>/dev/null | grep -q '^v22\.'; then
  echo "Installing Node.js 22 via NodeSource ..."
  sudo install -d -m 0755 /usr/share/keyrings
  curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | sudo gpg --dearmor --batch --yes -o /usr/share/keyrings/nodesource.gpg
  sudo chmod 644 /usr/share/keyrings/nodesource.gpg
  printf 'Types: deb\nURIs: https://deb.nodesource.com/node_22.x\nSuites: nodistro\nComponents: main\nArchitectures: %s\nSigned-By: /usr/share/keyrings/nodesource.gpg\n' \
    "$(dpkg --print-architecture)" \
    | sudo tee /etc/apt/sources.list.d/nodesource.sources > /dev/null
  wait_for_apt
  sudo apt update
  sudo apt install -y nodejs
else
  echo "Node.js 22 already installed, skipping."
fi

###############################################################################
# npm global prefix -- user-owned, no sudo needed                            #
###############################################################################

NPM_GLOBAL="$HOME/.npm-global"
mkdir -p "$NPM_GLOBAL"
npm config set prefix "$NPM_GLOBAL"
export PATH="$NPM_GLOBAL/bin:$PATH"

ZPROFILE="$HOME/.zprofile"
if ! grep -qF 'npm-global' "$ZPROFILE" 2>/dev/null; then
  # shellcheck disable=SC2016
  printf '\nexport PATH="$HOME/.npm-global/bin:$PATH"\n' >> "$ZPROFILE"
fi

###############################################################################
# Claude CLI -- via official apt repository                                   #
###############################################################################

if ! command -v claude > /dev/null 2>&1; then
  echo "Installing Claude CLI ..."
  sudo install -d -m 0755 /etc/apt/keyrings
  sudo curl -fsSL https://downloads.claude.ai/keys/claude-code.asc \
    -o /etc/apt/keyrings/claude-code.asc
  echo "deb [signed-by=/etc/apt/keyrings/claude-code.asc] https://downloads.claude.ai/claude-code/apt/stable stable main" \
    | sudo tee /etc/apt/sources.list.d/claude-code.list > /dev/null
  wait_for_apt
  sudo apt update
  sudo apt install -y claude-code
else
  echo "Claude CLI already installed, skipping."
fi

###############################################################################
# zsh                                                                         #
###############################################################################

shell_path="$(command -v zsh)"
echo "Ensuring default shell is zsh at '$shell_path' ..."
if ! grep "$shell_path" /etc/shells > /dev/null 2>&1; then
  sudo sh -c "echo $shell_path >> /etc/shells"
fi
if [ "$SHELL" != "$shell_path" ]; then
  sudo chsh -s "$shell_path" "$USER"
fi

###############################################################################
# SSH -- openssh-server for remote access                                     #
###############################################################################

sudo apt install -y openssh-server
sudo systemctl enable ssh
sudo systemctl start ssh

[ -f ~/.ssh/id_ed25519 ] || ssh-keygen -t ed25519 -N '' -f ~/.ssh/id_ed25519 -C "openclaw@$(hostname)"

###############################################################################
# VNC -- gnome-remote-desktop (shares existing Wayland/GNOME session)        #
###############################################################################

# Ubuntu 26.04 Desktop runs GNOME exclusively on Wayland. Traditional VNC
# servers (TigerVNC, x11vnc) require X11 and do not work. gnome-remote-desktop
# captures the live Wayland session via PipeWire and serves it over VNC (RFB)
# on port 5900. Credentials must be configured manually after install (step 8).

sudo apt install -y gnome-remote-desktop

# Enable the user service; it starts automatically when the GNOME session loads.
# Failure is non-fatal here in case DBUS is not available (e.g. SSH-only run).
systemctl --user enable gnome-remote-desktop.service 2>/dev/null || true

# Keep user session alive between logins so the service survives at boot.
sudo loginctl enable-linger "$USER"

# GDM autologin: ensures a GNOME session is always running at boot so
# gnome-remote-desktop has a session to attach to. Ubuntu Desktop ships
# /etc/gdm3/custom.conf with these lines commented out; this uncomments them.
if ! sudo grep -q "^AutomaticLoginEnable=true" /etc/gdm3/custom.conf 2>/dev/null; then
  echo "Configuring GDM autologin for $USER ..."
  sudo sed -i \
    -e 's/^\s*#\s*AutomaticLoginEnable\s*=.*/AutomaticLoginEnable=true/' \
    -e "s/^\s*#\s*AutomaticLogin\s*=.*/AutomaticLogin=$USER/" \
    /etc/gdm3/custom.conf
fi

###############################################################################
# Tailscale -- official apt repository                                        #
###############################################################################

if ! command -v tailscale > /dev/null 2>&1; then
  echo "Installing Tailscale ..."
  # shellcheck disable=SC1091
  DISTRO_CODENAME="$(. /etc/os-release && echo "$VERSION_CODENAME")"
  curl -fsSL "https://pkgs.tailscale.com/stable/ubuntu/${DISTRO_CODENAME}.noarmor.gpg" \
    | sudo tee /usr/share/keyrings/tailscale-archive-keyring.gpg > /dev/null
  curl -fsSL "https://pkgs.tailscale.com/stable/ubuntu/${DISTRO_CODENAME}.tailscale-keyring.list" \
    | sudo tee /etc/apt/sources.list.d/tailscale.list > /dev/null
  wait_for_apt
  sudo apt update
  sudo apt install -y tailscale
fi

sudo systemctl enable tailscaled
sudo systemctl start tailscaled

###############################################################################
# OpenClaw                                                                    #
###############################################################################

OPENCLAW_LATEST=$(npm view openclaw version 2>/dev/null || true)
OPENCLAW_INSTALLED=$(openclaw --version 2>/dev/null | awk '{print $2}' || true)

if [ -n "$OPENCLAW_LATEST" ] && [ "$OPENCLAW_INSTALLED" = "$OPENCLAW_LATEST" ]; then
  echo "OpenClaw $OPENCLAW_INSTALLED is already up to date, skipping."
else
  echo "Installing/updating OpenClaw ($OPENCLAW_INSTALLED -> $OPENCLAW_LATEST) ..."
  curl -fsSL 'https://openclaw.ai/install.sh' | bash -s -- --no-onboard
fi

###############################################################################
# Git snapshot cron -- every 15 minutes                                       #
###############################################################################

if ! crontab -l 2>/dev/null | grep -qF '.openclaw'; then
  (
    crontab -l 2>/dev/null
    cat <<'CRONEOF'
*/15 * * * * cd $HOME/.openclaw && git add -A && git commit -m "auto snapshot $(date '+\%Y-\%m-\%d \%H:\%M')" && git push 2>/dev/null || true
CRONEOF
  ) | crontab -
  echo "Cron job for ~/.openclaw snapshots added."
else
  echo "OpenClaw cron job already present, skipping."
fi

###############################################################################
# Time sync -- clock skew breaks WhatsApp and OAuth flows                    #
###############################################################################

sudo systemctl restart systemd-timesyncd

###############################################################################
# Summary                                                                     #
###############################################################################

LOCAL_IP="$(hostname -I | awk '{print $1}')"

echo ""
echo "============================================================"
echo "Setup complete."
echo ""
echo "Local IP:  $LOCAL_IP"
echo "SSH:       ssh $USER@$LOCAL_IP"
echo "VNC:       $LOCAL_IP:5900  (gnome-remote-desktop, port 5900)"
echo "           (credentials must be configured -- see step 8 below)"
echo ""
echo "Tailscale: daemon started -- run 'sudo tailscale up' to authenticate."
echo "After Tailscale auth, SSH and VNC work from anywhere via Tailscale IP."
echo ""
echo "Manual steps required:"
echo ""
echo "  1. claude"
echo "     Authenticate Claude CLI (interactive TTY required)"
echo ""
echo "  2. openclaw models auth login --provider anthropic --method cli --set-default"
echo "     Wire OpenClaw to Claude CLI (interactive TTY required)"
echo ""
echo "  3. sudo tailscale up"
echo "     Authenticate Tailscale"
echo ""
echo "  4. openclaw onboard --install-daemon"
echo "     Complete OpenClaw setup"
echo ""
echo "  5. openclaw configure (or use the dashboard)"
echo "     Link channels"
echo ""
echo "  6. gogcli auth login"
echo "     Authenticate Google Workspace CLI (opens browser)"
echo ""
echo "  7. Set git identity:"
echo "       git config --global user.name \"Your Name\""
echo "       git config --global user.email \"you@example.com\""
echo ""
echo "  8. gh auth login"
echo "     Authenticate GitHub CLI"
echo ""
echo "  9. Verify clock sync before attempting WhatsApp or Slack linking:"
echo "       timedatectl"
echo "     NTP synchronized should read 'yes'"
echo ""
echo " 10. Set up WhatsApp channel"
echo "     Requires scanning QR code in browser -- use VNC if no physical display"
echo ""
echo " 11. SSH keys:"
echo "     Public key for GitHub and outbound access: ~/.ssh/id_ed25519.pub"
echo "     To allow SSH into this machine:"
echo "       ssh-copy-id $USER@$LOCAL_IP"
echo "     or append manually to ~/.ssh/authorized_keys"
echo ""
echo " 12. Initialize ~/.openclaw as a git repo and add remote:"
echo "       git -C ~/.openclaw init"
echo "       git -C ~/.openclaw remote add origin <YOUR_REMOTE_URL>"
echo "     (cron job silently no-ops until this is done)"
echo ""
echo " 13. Configure VNC credentials (required before VNC will accept connections):"
echo "       grdctl vnc set-auth-method password"
echo "       grdctl vnc set-password YOUR_VNC_PASSWORD"
echo "       grdctl vnc enable"
echo "       systemctl --user restart gnome-remote-desktop.service"
echo "     Connect with any VNC client to $LOCAL_IP:5900"
echo "============================================================"
